# Repos (cloned by scripts/clone-repos.sh)
repos/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/

# Runtime
logs/*.log
!logs/agent_audit.log
*.db

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Claude Code ephemeral
.claude/plans/
.claude/settings.local.json
.claude/scheduled_tasks.lock

# Temp
tmp/*
!tmp/.gitkeep
.gitnexus
core
.coverage
.last_compile

# Local test/compile cruft
.coverage
.coverage.*
coverage.json
.last_compile

# Backup artifacts (bundles, archives — never commit binaries)
backups/

# Compiler/profiling residue (PGO instrumented runs leave these)
*.profraw
*.profdata

# MkDocs — generated content populated by scripts/docs/build-site-src.sh
# Hand-written pages (index.md, topics/index.md, etc.) are tracked individually.
site/
site_src/topics/*.md
!site_src/topics/index.md
site_src/deep-dives/*.md
!site_src/deep-dives/index.md
site_src/stories/recent-results.md
site_src/subsystems/orchestrator/
site_src/subsystems/research/
