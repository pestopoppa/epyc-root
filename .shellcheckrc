# ShellCheck configuration
# https://www.shellcheck.net/wiki/

# Disable warnings that are false positives or intentional patterns:

# SC1090: Can't follow non-constant source - we use dynamic sourcing intentionally
# SC1091: Not following source file - same as above
disable=SC1090,SC1091

# SC2034: Variable appears unused - often config vars for future use or exports
disable=SC2034

# SC2043: Loop will only run once - often intentional for code structure
disable=SC2043
